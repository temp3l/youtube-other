{
  "name": "mediaforge",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.16.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "youtube:auth": "tsx scripts/youtube-auth.ts",
    "build": "pnpm -r --if-present build",
    "test": "pnpm test:unit && pnpm test:integration && pnpm test:e2e",
    "test:unit": "vitest run -c vitest.unit.config.ts",
    "test:integration": "vitest run -c vitest.integration.config.ts",
    "test:e2e": "vitest run -c vitest.e2e.config.ts",
    "lint": "eslint .",
    "typecheck": "pnpm -r --if-present typecheck",
    "format": "prettier --write .",
    "doctor": "node apps/cli/dist/index.js doctor",
    "mediaforge": "node apps/cli/dist/index.js",
    "episode:inspect": "node apps/cli/dist/index.js episode inspect",
    "episode:dry-run": "node apps/cli/dist/index.js episode dry-run",
    "episode:analyze": "node apps/cli/dist/index.js episode analyze",
    "episode:plan": "node apps/cli/dist/index.js episode plan",
    "episode:english": "node apps/cli/dist/index.js episode english",
    "episode:localized": "node apps/cli/dist/index.js episode localized",
    "episode:short": "node apps/cli/dist/index.js episode short",
    "episode:status": "node apps/cli/dist/index.js episode status",
    "episode:validate": "node apps/cli/dist/index.js episode validate",
    "episode:review:prepare": "node apps/cli/dist/index.js episode review prepare",
    "episode:review:approve": "node apps/cli/dist/index.js episode review approve",
    "episode:review:reject": "node apps/cli/dist/index.js episode review reject",
    "episode:review:status": "node apps/cli/dist/index.js episode review status",
    "db:migrate": "pnpm --filter @mediaforge/cli db:migrate",
    "transcript:generate": "node apps/cli/dist/index.js transcript generate",
    "transcript:normalize": "node apps/cli/dist/index.js transcript normalize",
    "transcript:validate": "node apps/cli/dist/index.js transcript validate",
    "metadata:youtube": "node apps/cli/dist/index.js metadata youtube",
    "metadata:youtube:curl": "bash scripts/generate-youtube-metadata.sh",
    "test:metadata": "vitest run packages/metadata/src/youtube-metadata.unit.test.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@types/node": "^22.16.5",
    "eslint": "^9.30.1",
    "globals": "^16.3.0",
    "prettier": "^3.6.2",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.37.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^17.4.2",
    "googleapis": "^173.0.0",
    "pino": "^9.8.0",
    "sharp": "^0.34.3",
    "zod": "^4.0.14"
  }
}
