MEDIAFORGE_WORKSPACE=./episodes
MEDIAFORGE_DB_PATH=./.mediaforge.sqlite
MEDIAFORGE_LOG_LEVEL=info
MEDIAFORGE_DEFAULT_ASPECT_RATIO=16:9
MEDIAFORGE_OPENART_BATCH_SIZE=8
MEDIAFORGE_TTS_PROVIDER=openai-compatible
MEDIAFORGE_TRANSCRIPTION_PROVIDER=mock
MEDIAFORGE_IMAGE_PROVIDER=mock
MEDIAFORGE_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
MEDIAFORGE_OPENAI_COMPATIBLE_API_KEY=
MEDIAFORGE_OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
MEDIAFORGE_OPENAI_COMPATIBLE_TTS_VOICE=onyx
MEDIAFORGE_OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
MEDIAFORGE_OPENAI_SPEECH_VOICE=onyx
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_SPEECH_MODEL=gpt-4o-mini-tts
OPENAI_SPEECH_VOICE=onyx
MEDIAFORGE_WHISPER_BIN=./tools/whisper.cpp/build/bin/whisper-cli
MEDIAFORGE_WHISPER_MODEL=./tools/whisper.cpp/models/ggml-base.en.bin
