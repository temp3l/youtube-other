{
  "description": "Repository guardrails for focused Codex verification commands.",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "repo_root=$(git rev-parse --show-toplevel 2>/dev/null) && exec \"$repo_root/scripts/codex-command-guard.sh\"",
            "timeout": 10,
            "statusMessage": "checking repository command guardrails"
          }
        ]
      }
    ]
  }
}
